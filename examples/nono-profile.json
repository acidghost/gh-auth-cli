{
  "$schema": "https://github.com/nolabs-ai/nono/raw/refs/heads/main/crates/nono-cli/data/nono-profile.schema.json",
  "meta": {
    "name": "github-agent"
  },
  "network": {
    "allow_domain": ["api.github.com"],
    "credentials": ["github"],
    "custom_credentials": {
      "github": {
        "upstream": "https://api.github.com",
        "credential_key": "cmd://github",
        "env_var": "GH_TOKEN",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}",
        "endpoint_rules": [
          {
            "method": "GET",
            "path": "/user"
          },
          {
            "method": "GET",
            "path": "/repos/*/*/**"
          }
        ]
      }
    }
  },
  "credential_capture": {
    "github": {
      "command": [
        "gh-auth-cli",
        "token",
        "--non-interactive",
        "--min-validity",
        "20m"
      ],
      "timeout_secs": 15,
      "cache_ttl_secs": 900,
      "cache_path_regex": "^/repos/([^/]+)"
    }
  }
}
